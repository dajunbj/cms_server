        p.code AS parent_code,
        ROW_NUMBER() OVER (
          PARTITION BY a.code
          ORDER BY CASE WHEN a.company_id = #{companyId} THEN 0 ELSE 1 END, a.id
        ) rn
      FROM acct_category a
      LEFT JOIN acct_category p ON p.id = a.parent_id
      WHERE a.is_active = 1
        AND (a.valid_from IS NULL OR a.valid_from &lt;= CURRENT_DATE())
        AND (a.valid_to   IS NULL OR a.valid_to   &gt;= CURRENT_DATE())
        AND (a.company_id = #{companyId} OR a.company_id IS NULL)
    )
    SELECT id, code, level_no, sort_no, name_ja, name_zh, parent_code
    FROM ranked
    WHERE rn = 1
    ORDER BY level_no, sort_no, id
  </select>
  -->

  <!-- 懒加载 SQL（整块注释；当前不用）
  <select id="selectRoots" parameterType="long" resultMap="RowMap">...</select>
  <select id="selectChildrenByParentCode" resultMap="RowMap">...</select>
  <select id="existsChildren" resultType="int">...</select>
  -->

</mapper>
